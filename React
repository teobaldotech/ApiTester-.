import React, { useState, useEffect } from "react";

export default function ApiTesterPro() {
  const [activeTab, setActiveTab] = useState("rest");

  const [theme, setTheme] = useState("dark");

  const [environment, setEnvironment] = useState("DEV");

  const environments = {
    DEV: "https://dev.api.com",
    PROD: "https://api.com",
  };

  const [url, setUrl] = useState("");
  const [method, setMethod] = useState("GET");

  const [jwt, setJwt] = useState("");

  const [headers, setHeaders] = useState(`{
  "Content-Type": "application/json"
}`);

  const [body, setBody] = useState(`{
  "nome": "Teste"
}`);

  const [response, setResponse] = useState("");

  const [status, setStatus] = useState("");

  const [loading, setLoading] = useState(false);

  const [collections, setCollections] = useState([]);

  const [collectionName, setCollectionName] = useState("");

  const [graphqlQuery, setGraphqlQuery] = useState(`{
  users {
    id
    name
  }
}`);

  const [curlCommand, setCurlCommand] = useState("");

  const [wsMessages, setWsMessages] = useState([]);

  const [wsInput, setWsInput] = useState("");

  const [socket, setSocket] = useState(null);

  const [file, setFile] = useState(null);

  const isDark = theme === "dark";

  useEffect(() => {
    const saved = localStorage.getItem("collections");

    if (saved) {
      setCollections(JSON.parse(saved));
    }
  }, []);

  const sendRequest = async () => {
    try {
      setLoading(true);

      let parsedHeaders = JSON.parse(headers);

      if (jwt) {
        parsedHeaders.Authorization = `Bearer ${jwt}`;
      }

      const finalUrl = url.startsWith("http")
        ? url
        : environments[environment] + url;

      const options = {
        method,
        headers: parsedHeaders,
      };

      if (method !== "GET") {
        options.body = body;
      }

      if (file) {
        const formData = new FormData();

        formData.append("file", file);

        options.body = formData;

        delete options.headers["Content-Type"];
      }

      const res = await fetch(finalUrl, options);

      const text = await res.text();

      setStatus(`${res.status} ${res.statusText}`);

      try {
        setResponse(
          JSON.stringify(JSON.parse(text), null, 2)
        );
      } catch {
        setResponse(text);
      }
    } catch (err) {
      setResponse("Erro: " + err.message);
    } finally {
      setLoading(false);
    }
  };

  const saveCollection = () => {
    const newCollection = {
      name: collectionName,
      url,
      method,
      headers,
      body,
    };

    const updated = [...collections, newCollection];

    setCollections(updated);

    localStorage.setItem(
      "collections",
      JSON.stringify(updated)
    );

    alert("Collection salva!");
  };

  const loadCollection = (item) => {
    setUrl(item.url);
    setMethod(item.method);
    setHeaders(item.headers);
    setBody(item.body);
  };

  const exportCollections = () => {
    const blob = new Blob(
      [JSON.stringify(collections, null, 2)],
      { type: "application/json" }
    );

    const link = document.createElement("a");

    link.href = URL.createObjectURL(blob);

    link.download = "collections.json";

    link.click();
  };

  const importCurl = () => {
    try {
      const parts = curlCommand.split(" ");

      const curlUrl = parts.find((p) =>
        p.startsWith("http")
      );

      setUrl(curlUrl || "");

      if (curlCommand.includes("-X POST")) {
        setMethod("POST");
      }

      if (curlCommand.includes("-X PUT")) {
        setMethod("PUT");
      }

      alert("CURL importado!");
    } catch {
      alert("Erro ao importar CURL");
    }
  };

  const connectWebSocket = () => {
    const ws = new WebSocket(url);

    ws.onopen = () => {
      setWsMessages((prev) => [
        ...prev,
        "✅ Conectado",
      ]);
    };

    ws.onmessage = (event) => {
      setWsMessages((prev) => [
        ...prev,
        "📩 " + event.data,
      ]);
    };

    ws.onerror = () => {
      setWsMessages((prev) => [
        ...prev,
        "❌ Erro WebSocket",
      ]);
    };

    setSocket(ws);
  };

  const sendWsMessage = () => {
    if (socket) {
      socket.send(wsInput);

      setWsMessages((prev) => [
        ...prev,
        "📤 " + wsInput,
      ]);

      setWsInput("");
    }
  };

  const runGraphQL = async () => {
    try {
      const res = await fetch(url, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          query: graphqlQuery,
        }),
      });

      const data = await res.json();

      setResponse(
        JSON.stringify(data, null, 2)
      );
    } catch (err) {
      setResponse(err.message);
    }
  };

  return (
    <div
      style={{
        ...styles.body(isDark),
      }}
    >
      <div style={styles.container(isDark)}>
        <h1 style={styles.title}>
          🚀 API TESTER ULTRA
        </h1>

        <div style={styles.tabs}>
          {[
            "rest",
            "graphql",
            "websocket",
            "collections",
            "curl",
          ].map((tab) => (
            <button
              key={tab}
              onClick={() => setActiveTab(tab)}
              style={styles.tab(
                activeTab === tab,
                isDark
              )}
            >
              {tab.toUpperCase()}
            </button>
          ))}
        </div>

        <div style={styles.topBar}>
          <select
            value={theme}
            onChange={(e) =>
              setTheme(e.target.value)
            }
            style={styles.input(isDark)}
          >
            <option value="dark">
              Dark
            </option>

            <option value="light">
              Light
            </option>
          </select>

          <select
            value={environment}
            onChange={(e) =>
              setEnvironment(e.target.value)
            }
            style={styles.input(isDark)}
          >
            <option value="DEV">
              DEV
            </option>

            <option value="PROD">
              PROD
            </option>
          </select>
        </div>

        {activeTab === "rest" && (
          <>
            <input
              type="text"
              placeholder="/users"
              value={url}
              onChange={(e) =>
                setUrl(e.target.value)
              }
              style={styles.input(isDark)}
            />

            <select
              value={method}
              onChange={(e) =>
                setMethod(e.target.value)
              }
              style={styles.input(isDark)}
            >
              <option>GET</option>
              <option>POST</option>
              <option>PUT</option>
              <option>DELETE</option>
              <option>PATCH</option>
            </select>

            <input
              type="text"
              placeholder="JWT Token"
              value={jwt}
              onChange={(e) =>
                setJwt(e.target.value)
              }
              style={styles.input(isDark)}
            />

            <textarea
              value={headers}
              onChange={(e) =>
                setHeaders(e.target.value)
              }
              style={styles.editor(isDark)}
            />

            {method !== "GET" && (
              <textarea
                value={body}
                onChange={(e) =>
                  setBody(e.target.value)
                }
                style={styles.editor(isDark)}
              />
            )}

            <input
              type="file"
              onChange={(e) =>
                setFile(e.target.files[0])
              }
              style={styles.input(isDark)}
            />

            <button
              onClick={sendRequest}
              style={styles.button}
            >
              {loading
                ? "⏳ Enviando..."
                : "🚀 Enviar"}
            </button>
          </>
        )}

        {activeTab === "graphql" && (
          <>
            <input
              type="text"
              placeholder="GraphQL Endpoint"
              value={url}
              onChange={(e) =>
                setUrl(e.target.value)
              }
              style={styles.input(isDark)}
            />

            <textarea
              value={graphqlQuery}
              onChange={(e) =>
                setGraphqlQuery(
                  e.target.value
                )
              }
              style={styles.editor(isDark)}
            />

            <button
              onClick={runGraphQL}
              style={styles.button}
            >
              ▶ Executar Query
            </button>
          </>
        )}

        {activeTab === "websocket" && (
          <>
            <input
              type="text"
              placeholder="wss://..."
              value={url}
              onChange={(e) =>
                setUrl(e.target.value)
              }
              style={styles.input(isDark)}
            />

            <button
              onClick={connectWebSocket}
              style={styles.button}
            >
              🔌 Conectar
            </button>

            <input
              type="text"
              placeholder="Mensagem"
              value={wsInput}
              onChange={(e) =>
                setWsInput(e.target.value)
              }
              style={styles.input(isDark)}
            />

            <button
              onClick={sendWsMessage}
              style={styles.button}
            >
              📤 Enviar
            </button>

            <div style={styles.response(isDark)}>
              {wsMessages.map((m, i) => (
                <div key={i}>{m}</div>
              ))}
            </div>
          </>
        )}

        {activeTab === "collections" && (
          <>
            <input
              type="text"
              placeholder="Nome da Collection"
              value={collectionName}
              onChange={(e) =>
                setCollectionName(
                  e.target.value
                )
              }
              style={styles.input(isDark)}
            />

            <button
              onClick={saveCollection}
              style={styles.button}
            >
              💾 Salvar Collection
            </button>

            <button
              onClick={exportCollections}
              style={styles.button}
            >
              📦 Exportar JSON
            </button>

            <div style={styles.response(isDark)}>
              {collections.map(
                (item, index) => (
                  <div
                    key={index}
                    style={
                      styles.collectionItem(
                        isDark
                      )
                    }
                    onClick={() =>
                      loadCollection(item)
                    }
                  >
                    {item.name}
                  </div>
                )
              )}
            </div>
          </>
        )}

        {activeTab === "curl" && (
          <>
            <textarea
              value={curlCommand}
              onChange={(e) =>
                setCurlCommand(
                  e.target.value
                )
              }
              style={styles.editor(isDark)}
            />

            <button
              onClick={importCurl}
              style={styles.button}
            >
              📥 Importar CURL
            </button>
          </>
        )}

        <div style={styles.status(isDark)}>
          {status}
        </div>

        <div style={styles.response(isDark)}>
          <pre>{response}</pre>
        </div>
      </div>
    </div>
  );
}

const styles = {
  body: (dark) => ({
    minHeight: "100vh",
    background: dark
      ? "#020617"
      : "#f1f5f9",
    color: dark ? "#fff" : "#000",
    padding: 20,
    fontFamily: "Arial",
  }),

  container: (dark) => ({
    maxWidth: 1200,
    margin: "0 auto",
    background: dark
      ? "#0f172a"
      : "#fff",
    padding: 25,
    borderRadius: 20,
  }),

  title: {
    textAlign: "center",
    marginBottom: 20,
  },

  tabs: {
    display: "flex",
    gap: 10,
    marginBottom: 20,
    flexWrap: "wrap",
  },

  tab: (active, dark) => ({
    padding: 10,
    border: "none",
    borderRadius: 10,
    cursor: "pointer",
    background: active
      ? "#2563eb"
      : dark
      ? "#1e293b"
      : "#cbd5e1",
    color: "#fff",
  }),

  topBar: {
    display: "flex",
    gap: 10,
    marginBottom: 20,
  },

  input: (dark) => ({
    width: "100%",
    padding: 12,
    marginBottom: 15,
    borderRadius: 10,
    border: "none",
    background: dark
      ? "#1e293b"
      : "#e2e8f0",
    color: dark ? "#fff" : "#000",
  }),

  editor: (dark) => ({
    width: "100%",
    minHeight: 180,
    padding: 15,
    marginBottom: 15,
    borderRadius: 10,
    border: "none",
    fontFamily: "monospace",
    background: dark
      ? "#1e293b"
      : "#e2e8f0",
    color: dark ? "#fff" : "#000",
  }),

  button: {
    width: "100%",
    padding: 14,
    border: "none",
    borderRadius: 10,
    background: "#2563eb",
    color: "#fff",
    fontSize: 16,
    marginBottom: 15,
    cursor: "pointer",
  },

  response: (dark) => ({
    background: dark
      ? "#020617"
      : "#e2e8f0",
    padding: 15,
    borderRadius: 10,
    overflowX: "auto",
  }),

  status: (dark) => ({
    marginBottom: 15,
    padding: 10,
    borderRadius: 10,
    background: dark
      ? "#1e293b"
      : "#cbd5e1",
  }),

  collectionItem: (dark) => ({
    padding: 12,
    marginBottom: 10,
    borderRadius: 10,
    background: dark
      ? "#1e293b"
      : "#cbd5e1",
    cursor: "pointer",
  }),
};